# Environment Configuration for ASM Backend

# Application
NODE_ENV=development
PORT=5000

# Database
# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://user:password@localhost:5432/asm_db

# Authentication
# IMPORTANT: Change this to a secure random string (minimum 32 characters)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_jwt_secret_key_here_change_in_production_minimum_32_characters
JWT_EXPIRE=7d
BCRYPT_ROUNDS=10

# AWS S3 Configuration
# Required for document upload functionality
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=asm-documents

# CORS
# Comma-separated list of allowed origins or * for all
CORS_ORIGIN=*

# Logging
LOG_LEVEL=debug